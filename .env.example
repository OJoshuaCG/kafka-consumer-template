# =============================================================================
# Global settings (sin prefijo) — compartidas por todo el proyecto
# =============================================================================
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT    # PLAINTEXT | SASL_SSL
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Database
DATABASE_URL=postgresql://kafka:kafka@localhost:5432/kafka_consumer

# Redis (idempotencia, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Métricas
METRICS_PORT=9090
METRICS_ENABLED=true

# Health check
HEALTH_FILE_PATH=/tmp/healthcheck
HEALTH_WRITE_INTERVAL_SECONDS=10

# =============================================================================
# Per-consumer settings — usan env prefix para evitar colisiones.
# Cada consumer tiene SU propio prefijo.
# =============================================================================

# Example consumer (prefijo EXAMPLE_)
EXAMPLE_TOPIC=example-events
EXAMPLE_GROUP_ID=example-consumer
EXAMPLE_DLQ_TOPIC=example-events-dlq
EXAMPLE_BATCH_SIZE=100
EXAMPLE_MAX_RETRIES=3

# Para agregar un nuevo consumer (ej. whatsapp):
# WHATSAPP_TOPIC=whatsapp-events
# WHATSAPP_GROUP_ID=whatsapp-consumer
# WHATSAPP_DLQ_TOPIC=whatsapp-events-dlq
